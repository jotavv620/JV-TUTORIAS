{
  "version": 2,
  "public": true,
  "buildCommand": "pnpm build",
  "outputDirectory": "dist",
  "framework": "vite",
  "nodeVersion": "24.x",
  "functions": {},
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/index.html",
      "status": 200
    }
  ]
}
